{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    // "declaration": true,
    // "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node16",
    "types": ["jest", "node"],
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "include": ["src/**/*.ts", "prisma/seed.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

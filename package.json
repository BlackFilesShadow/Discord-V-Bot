{
  "name": "discord-v-bot",
  "version": "1.0.0",
  "description": "Maximaler Discord-Bot mit GUID-basierter Usertrennung, Upload/Download-System, Moderation, AI, Giveaways, Leveling, Polls, OAuth2 Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "lint": "eslint src/ --ext .ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "deploy-commands": "ts-node src/commands/deploy.ts",
    "dashboard": "ts-node src/dashboard/server.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "ajv": "^8.17.1",
    "archiver": "^7.0.1",
    "argon2": "^0.41.1",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "fast-xml-parser": "^4.5.0",
    "helmet": "^8.0.0",
    "jsonschema": "^1.4.1",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "rss-parser": "^3.13.0",
    "speakeasy": "^2.0.0",
    "unzipper": "^0.12.3",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/passport": "^1.0.16",
    "@types/passport-discord": "^0.1.13",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon": "^3.1.7",
    "prisma": "^5.20.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

// Prisma Schema für Discord-V-Bot
// Deckt alle Sektionen der README ab:
// 1. Registrierung & GUID-basierte Usertrennung
// 2. Upload- & Download-System
// 3. Download-System
// 4. Moderation, AI & Sicherheit
// 6. Giveaway-System
// 7. API-Integration & Web-Dashboard
// 8. Level- & XP-System
// 9. Automatische Rollenvergabe
// 10. Umfrage- & Abstimmungssystem
// 11. Logging & Analytics
// 12. Discord OAuth2-Organisation

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SEKTION 1: Registrierung & GUID-basierte Usertrennung
// ============================================================

model User {
  id                     String     @id @default(uuid()) // Kryptografisch sichere GUID (UUIDv4)
  discordId              String     @unique
  username               String
  discriminator          String     @default("")
  email                  String?
  role                   UserRole   @default(USER)
  status                 UserStatus @default(ACTIVE)
  isManufacturer         Boolean    @default(false)
  manufacturerApprovedAt DateTime?
  manufacturerApprovedBy String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Relations
  packages            Package[]
  uploads             Upload[]
  downloads           Download[]
  moderationCases     ModerationCase[]     @relation("TargetUser")
  moderationActions   ModerationCase[]     @relation("ModeratorUser")
  appeals             Appeal[]
  giveawayEntries     GiveawayEntry[]
  giveawaysCreated    Giveaway[]
  xpRecords           XpRecord[]
  levelData           LevelData[]
  pollVotes           PollVote[]
  auditLogs           AuditLog[]           @relation("AuditUser")
  auditActions        AuditLog[]           @relation("AuditActor")
  sessions            Session[]
  oauthTokens         OAuthToken[]
  twoFactorAuth       TwoFactorAuth?
  manufacturerRequest ManufacturerRequest?
  oneTimePasswords    OneTimePassword[]
  roleAssignments     UserRoleAssignment[]
  inviteTracking      InviteTracking[]
  feedSubscriptions   FeedSubscription[]
  gdprConsent         GdprConsent?
  securityEvents      SecurityEvent[]      @relation("SecurityUser")
  apiKeys             ApiKey[]

  @@index([discordId])
  @@index([role])
  @@index([status])
}

enum UserRole {
  USER
  MANUFACTURER
  MODERATOR
  ADMIN
  SUPER_ADMIN
  DEVELOPER
  READ_ONLY
  CUSTOM
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
  SUSPENDED
  PENDING_VERIFICATION
}

// Hersteller-Anfragen (Admin per PN)
model ManufacturerRequest {
  id         String        @id @default(uuid())
  userId     String        @unique
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     RequestStatus @default(PENDING)
  reason     String?
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status])
}

enum RequestStatus {
  PENDING
  APPROVED
  DENIED
}

// Einmal-Passwörter (hochkomplex, zeitlich limitiert, GUID-gebunden)
model OneTimePassword {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String // Argon2 Hash
  expiresAt    DateTime
  usedAt       DateTime?
  isUsed       Boolean   @default(false)
  isRevoked    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================
// SEKTION 2 & 3: Upload- & Download-System
// ============================================================

// Pakete (GUID-gebunden, frei benennbar)
model Package {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  status        PackageStatus @default(ACTIVE)
  isDeleted     Boolean       @default(false) // Soft-Delete
  deletedAt     DateTime?
  deletedBy     String?
  totalSize     BigInt        @default(0)
  fileCount     Int           @default(0)
  downloadCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  files       Upload[]
  downloads   Download[]
  validations ValidationResult[]

  @@unique([userId, name]) // Keine Namenskonflikte pro GUID-Bereich
  @@index([userId])
  @@index([status])
  @@index([isDeleted])
  @@index([name])
}

enum PackageStatus {
  ACTIVE
  QUARANTINED
  DELETED
  VALIDATING
}

// Einzelne Dateien (bis 2 GB, Chunked-Upload)
model Upload {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId        String
  package          Package          @relation(fields: [packageId], references: [id], onDelete: Cascade)
  fileName         String
  originalName     String
  filePath         String
  fileSize         BigInt
  mimeType         String
  fileHash         String // SHA-256 Integrity Hash
  fileType         FileType
  isValid          Boolean          @default(false)
  validationStatus ValidationStatus @default(PENDING)
  isQuarantined    Boolean          @default(false)
  quarantineReason String?
  isDeleted        Boolean          @default(false)
  deletedAt        DateTime?
  chunkCount       Int              @default(1)
  isChunked        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  validations     ValidationResult[]
  downloadRecords Download[]

  @@index([userId])
  @@index([packageId])
  @@index([fileType])
  @@index([validationStatus])
  @@index([isDeleted])
}

enum FileType {
  XML
  JSON
  OTHER
}

enum ValidationStatus {
  PENDING
  VALID
  INVALID
  ERROR
  QUARANTINED
}

// Validierungsergebnisse (XML- & JSON-Validator)
model ValidationResult {
  id          String   @id @default(uuid())
  uploadId    String?
  upload      Upload?  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  packageId   String?
  package     Package? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  isValid     Boolean
  errors      Json? // Detaillierte Fehlerliste
  warnings    Json? // Warnungen
  suggestions Json? // Vorschläge
  validatedBy String? // "system" oder Admin-GUID
  createdAt   DateTime @default(now())

  @@index([uploadId])
  @@index([packageId])
}

// Download-Tracking
model Download {
  id           String       @id @default(uuid())
  userId       String?
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  packageId    String?
  package      Package?     @relation(fields: [packageId], references: [id], onDelete: SetNull)
  uploadId     String?
  upload       Upload?      @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  downloadType DownloadType
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  @@index([userId])
  @@index([packageId])
  @@index([uploadId])
  @@index([createdAt])
}

enum DownloadType {
  SINGLE_FILE
  PACKAGE_ZIP
  PACKAGE_TAR
}

// ============================================================
// SEKTION 4: Moderation, AI & Sicherheit
// ============================================================

// Moderationsfall (Kick, Ban, Mute, Warn, Case-Management)
model ModerationCase {
  id              String           @id @default(uuid())
  caseNumber      Int              @unique @default(autoincrement())
  guildId         String? // Discord-Guild-ID (für Guild-Trennung; nullable für Legacy-Records)
  targetUserId    String
  targetUser      User             @relation("TargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  moderatorId     String
  moderator       User             @relation("ModeratorUser", fields: [moderatorId], references: [id], onDelete: Cascade)
  action          ModerationAction
  reason          String
  details         String?
  duration        Int? // Dauer in Minuten (für Mute/Ban)
  expiresAt       DateTime?
  escalationLevel Int              @default(0)
  isActive        Boolean          @default(true)
  revokedAt       DateTime?
  revokedBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  appeals Appeal[]

  @@index([targetUserId])
  @@index([moderatorId])
  @@index([action])
  @@index([isActive])
  @@index([caseNumber])
  @@index([guildId])
}

enum ModerationAction {
  KICK
  BAN
  TEMP_BAN
  MUTE
  TEMP_MUTE
  WARN
  FILTER
  AUTO_MOD
  ESCALATION
}

// Appeal-System
model Appeal {
  id         String         @id @default(uuid())
  caseId     String
  case       ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason     String
  status     AppealStatus   @default(PENDING)
  reviewedBy String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([caseId])
  @@index([userId])
  @@index([status])
}

enum AppealStatus {
  PENDING
  APPROVED
  DENIED
  ESCALATED
}

// Auto-Mod Filter
model AutoModFilter {
  id         String           @id @default(uuid())
  pattern    String // Regex oder Keyword
  filterType FilterType
  action     ModerationAction @default(FILTER)
  severity   Int              @default(1)
  isActive   Boolean          @default(true)
  channelIds Json? // Optionale Channel-Beschränkung
  createdBy  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([filterType])
  @@index([isActive])
}

enum FilterType {
  KEYWORD
  REGEX
  LINK
  INVITE
  SPAM
  CAPS
  EMOJI_SPAM
  MENTION_SPAM
  CUSTOM
}

// Invite-Tracking
model InviteTracking {
  id         String    @id @default(uuid())
  inviteCode String    @unique
  inviterId  String
  inviter    User      @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  usesCount  Int       @default(0)
  maxUses    Int?
  expiresAt  DateTime?
  channelId  String?
  createdAt  DateTime  @default(now())

  @@index([inviterId])
}

// AI-Analyse (Sentiment, Toxicity)
model AiAnalysis {
  id           String         @id @default(uuid())
  messageId    String
  channelId    String
  userId       String
  analysisType AiAnalysisType
  score        Float
  label        String?
  details      Json?
  actionTaken  String?
  createdAt    DateTime       @default(now())

  @@index([userId])
  @@index([analysisType])
  @@index([createdAt])
}

enum AiAnalysisType {
  SENTIMENT
  TOXICITY
  CONTEXT
  TRANSLATION
  KNOWLEDGE
  CUSTOM
}

// ============================================================
// SEKTION 6: Giveaway-System
// ============================================================

model Giveaway {
  id             String         @id @default(uuid())
  creatorId      String
  creator        User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  channelId      String
  messageId      String? // Embed-Nachricht ID
  prize          String // Frei wählbarer Item-/Gegenstandsname
  description    String?
  duration       Int // Dauer in Sekunden
  endsAt         DateTime
  winnerId       String?
  winnerCount    Int            @default(1)
  status         GiveawayStatus @default(ACTIVE)
  minRole        String? // Mindestrolle
  blacklistRoles Json? // Blacklisted Rollen
  customEmoji    String? // Custom-Emoji für Teilnahme
  notifyRoleId   String? // Rolle die bei Beendigung gepingt wird
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  entries GiveawayEntry[]

  @@index([status])
  @@index([endsAt])
  @@index([channelId])
}

enum GiveawayStatus {
  ACTIVE
  ENDED
  CANCELLED
  REROLLED
}

model GiveawayEntry {
  id         String   @id @default(uuid())
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isWinner   Boolean  @default(false)
  enteredAt  DateTime @default(now())

  @@unique([giveawayId, userId]) // Keine Mehrfachteilnahme
  @@index([giveawayId])
  @@index([userId])
}

// ============================================================
// SEKTION 8: Level- & XP-System
// ============================================================

model LevelData {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId       String
  xp            BigInt    @default(0)
  level         Int       @default(0)
  totalMessages Int       @default(0)
  voiceMinutes  Int       @default(0)
  lastXpGain    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, guildId])
  @@index([guildId])
  @@index([level])
  @@index([xp])
}

model XpRecord {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildId     String
  amount      Int
  source      XpSource
  channelId   String?
  description String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([guildId])
  @@index([source])
  @@index([createdAt])
}

enum XpSource {
  MESSAGE
  VOICE
  EVENT
  REACTION
  BOOST
  ADMIN
  RESET
  CUSTOM
}

// XP-Konfiguration
model XpConfig {
  id                String   @id @default(uuid())
  messageXpMin      Int      @default(15)
  messageXpMax      Int      @default(25)
  voiceXpPerMinute  Int      @default(5)
  eventXpBonus      Int      @default(50)
  xpCooldownSeconds Int      @default(60) // Anti-Spam
  levelUpRoleIds    Json? // {level: roleId} Mapping
  levelMultiplier   Float    @default(1.0)
  isActive          Boolean  @default(true)
  // XP nur an User mit einer dieser Rollen vergeben (leer = alle)
  allowedRoleIds    Json? // string[] mit Discord-Rollen-IDs
  // XP nur in diesen Kanälen vergeben (leer = alle Kanäle)
  allowedChannelIds Json? // string[] mit Discord-Channel-IDs
  // Max-Level (Endstufe) und Belohnungsrolle bei Erreichen
  maxLevel          Int      @default(20)
  maxLevelRoleId    String? // Discord-Rollen-ID, optional
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Level-Belohnungen
model LevelReward {
  id        String   @id @default(uuid())
  level     Int      @unique
  roleId    String? // Discord Rolle
  reward    String? // Beschreibung der Belohnung
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([level])
}

// Server-spezifische Levelrollen
model LevelRole {
  id        String   @id @default(uuid())
  guildId   String // Discord Server ID
  level     Int
  roleId    String // Discord Rollen-ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, level])
  @@index([guildId])
  @@index([roleId])
}

// Server-spezifische Level-Up-Nachrichten
model LevelUpMessage {
  id        String   @id @default(uuid())
  guildId   String // Discord Server ID
  level     Int
  message   String // Nachricht (kann Platzhalter enthalten)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, level])
  @@index([guildId])
}

// ============================================================
// SEKTION 9: Automatische Rollenvergabe
// ============================================================

model AutoRole {
  id             String          @id @default(uuid())
  guildId        String? // Multi-Guild-Trennung (nullable für Altdaten; neue Einträge IMMER gesetzt)
  roleId         String
  roleName       String
  triggerType    AutoRoleTrigger
  triggerValue   String? // z.B. Emoji, Level, Event-Name
  channelId      String? // Für Reaction-Roles
  messageId      String? // Für Reaction-Roles
  isActive       Boolean         @default(true)
  expiresAt      DateTime? // Zeitlimitierte Rollen
  blacklistRoles Json? // Blacklisted Rollen
  whitelistRoles Json? // Whitelist Rollen
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([guildId])
  @@index([triggerType])
  @@index([isActive])
}

enum AutoRoleTrigger {
  JOIN
  REACTION
  LEVEL
  ACTIVITY
  EVENT
  GIVEAWAY
  CUSTOM
}

model UserRoleAssignment {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String
  assignedBy String // "auto" oder Admin-GUID
  reason     String?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([roleId])
  @@index([isActive])
}

// ============================================================
// SEKTION 10: Umfrage- & Abstimmungssystem
// ============================================================

model Poll {
  id            String     @id @default(uuid())
  creatorId     String
  channelId     String
  messageId     String?
  title         String
  description   String?
  options       Json // Array von {id, text, emoji}
  pollType      PollType   @default(PUBLIC)
  allowMultiple Boolean    @default(false)
  maxChoices    Int        @default(1)
  endsAt        DateTime?
  status        PollStatus @default(ACTIVE)
  totalVotes    Int        @default(0)
  results       Json? // Ergebnisse nach Abschluss
  notifyRoleId  String? // Rolle die bei Beendigung gepingt wird
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  votes PollVote[]

  @@index([status])
  @@index([channelId])
  @@index([endsAt])
}

enum PollType {
  PUBLIC
  ANONYMOUS
}

enum PollStatus {
  ACTIVE
  ENDED
  ARCHIVED
}

model PollVote {
  id        String   @id @default(uuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  optionId  String
  createdAt DateTime @default(now())

  @@unique([pollId, userId, optionId]) // Eine Stimme pro Option pro User
  @@index([pollId])
  @@index([userId])
}

// ============================================================
// SEKTION 7 & 12: OAuth2-Organisation & Web-Dashboard
// ============================================================

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  deviceInfo   String? // Device-Bindung
  ipAddress    String?
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([isActive])
}

/// Express-Session-Store-Tabelle fuer connect-pg-simple.
/// Wird durch deploy/sql/003_session_table.sql idempotent angelegt.
/// Hier nur deklariert, damit `prisma db push` sie NICHT als orphan droppt.
/// @@ignore haelt sie ausserhalb des Prisma-Clients (kein Code-Zugriff).
model pg_simple_session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
  @@ignore
}

model OAuthToken {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessTokenEnc  String? // Optional: Access-Token nur im RAM (Sektion 12)
  refreshTokenEnc String? // Verschlüsselter Refresh-Token
  tokenType       String    @default("Bearer")
  scope           String
  expiresAt       DateTime
  lastRefresh     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model TwoFactorAuth {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secretEnc           String? // Verschlüsselter TOTP Secret
  isEnabled           Boolean   @default(false)
  backupCodes         Json? // Verschlüsselte Backup-Codes
  webauthnEnabled     Boolean   @default(false)
  webauthnCredentials Json? // Array von WebAuthn Credentials
  verifiedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ============================================================
// SEKTION 11: Logging & Analytics + Audit-Log
// ============================================================

model AuditLog {
  id          String        @id @default(uuid())
  actorId     String?
  actor       User?         @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetId    String?
  target      User?         @relation("AuditUser", fields: [targetId], references: [id], onDelete: SetNull)
  action      String
  category    AuditCategory
  details     Json?
  ipAddress   String?
  userAgent   String?
  channelId   String?
  guildId     String?
  isImmutable Boolean       @default(true) // Revisionssicher, unveränderbar
  createdAt   DateTime      @default(now())

  @@index([actorId])
  @@index([targetId])
  @@index([action])
  @@index([category])
  @@index([createdAt])
}

enum AuditCategory {
  AUTH
  REGISTRATION
  UPLOAD
  DOWNLOAD
  MODERATION
  GIVEAWAY
  LEVEL
  ROLE
  POLL
  SECURITY
  ADMIN
  SYSTEM
  CONFIG
  GDPR
  AI
  FEED
  APPEAL
  TICKET
  NITRADO
  ECONOMY
  CASINO
  DASHBOARD
  WHITELIST
  FACTION
  SERVER_SETTINGS
}

// Security-Events
model SecurityEvent {
  id          String            @id @default(uuid())
  userId      String?
  user        User?             @relation("SecurityUser", fields: [userId], references: [id], onDelete: SetNull)
  eventType   SecurityEventType
  severity    SecuritySeverity
  description String
  details     Json?
  ipAddress   String?
  userAgent   String?
  isResolved  Boolean           @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())

  @@index([eventType])
  @@index([severity])
  @@index([userId])
  @@index([isResolved])
  @@index([createdAt])
}

enum SecurityEventType {
  LOGIN_FAILURE
  BRUTE_FORCE
  RATE_LIMIT_EXCEEDED
  SUSPICIOUS_ACTIVITY
  TOKEN_ABUSE
  UNAUTHORIZED_ACCESS
  DATA_BREACH_ATTEMPT
  MALWARE_DETECTED
  RAID_DETECTED
  SPAM_DETECTED
  IP_BLACKLISTED
  DEVICE_CHANGE
  PRIVILEGE_ESCALATION
  CUSTOM
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// IP Blacklist/Whitelist
model IpList {
  id        String    @id @default(uuid())
  ipAddress String    @unique
  listType  ListType
  reason    String?
  addedBy   String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([listType])
  @@index([ipAddress])
}

enum ListType {
  BLACKLIST
  WHITELIST
}

// ============================================================
// DSGVO-Compliance
// ============================================================

model GdprConsent {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataProcessing Boolean   @default(false)
  analytics      Boolean   @default(false)
  marketing      Boolean   @default(false)
  consentVersion String    @default("1.0")
  ipAddress      String?
  consentedAt    DateTime  @default(now())
  withdrawnAt    DateTime?
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

// Automatische Datenlöschung (DSGVO)
model DataDeletionRequest {
  id          String         @id @default(uuid())
  userId      String
  discordId   String
  requestType DeletionType
  status      DeletionStatus @default(PENDING)
  scheduledAt DateTime
  completedAt DateTime?
  details     Json?
  createdAt   DateTime       @default(now())

  @@index([status])
  @@index([scheduledAt])
}

enum DeletionType {
  FULL_DELETION
  PARTIAL_DELETION
  DATA_EXPORT
  ANONYMIZATION
}

enum DeletionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ============================================================
// Live-Feeds & externe APIs (Sektion 7)
// ============================================================

model Feed {
  id            String    @id @default(uuid())
  name          String
  feedType      FeedType
  url           String
  channelId     String // Ziel-Channel
  interval      Int       @default(300) // Sekunden
  lastChecked   DateTime?
  lastItemId    String?
  isActive      Boolean   @default(true)
  filters       Json? // Filterregeln
  mentionRoles  String[]  @default([]) // Rollen, die bei jedem neuen Eintrag gepingt werden
  webhookSecret String? // HMAC-Secret fuer eingehende Webhook-Posts (nur WEBHOOK-Typ)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  subscriptions FeedSubscription[]

  @@index([feedType])
  @@index([isActive])
}

enum FeedType {
  RSS
  TWITCH
  TWITTER
  STEAM
  NEWS
  WEBHOOK
  CUSTOM
}

model FeedSubscription {
  id        String   @id @default(uuid())
  feedId    String
  feed      Feed     @relation(fields: [feedId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifyDm  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([feedId, userId])
  @@index([feedId])
  @@index([userId])
}

// ============================================================
// Bot-Konfiguration (Admin-Config, Limits, Security-Policies)
// ============================================================

model BotConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  category    String   @default("general")
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([key])
}

// Rate-Limiting Tracking
model RateLimitEntry {
  id          String   @id @default(uuid())
  identifier  String // User-ID oder IP
  action      String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt   DateTime

  @@unique([identifier, action])
  @@index([identifier])
  @@index([expiresAt])
}

// ============================================================
// SEKTION 7: API-Key Management
// ============================================================

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  name        String
  keyHash     String    @unique // SHA-256 Hash des API-Keys
  keyPrefix   String // Erste 8 Zeichen für Identifikation
  permissions Json      @default("[]") // Array von erlaubten Aktionen
  rateLimit   Int       @default(100) // Requests pro Minute
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([keyHash])
  @@index([keyPrefix])
}

// ============================================================
// TICKET-SYSTEM (Sektion: Owner-Kontakt via DM-Bridge)
// ============================================================

enum TicketStatus {
  PENDING // Wartet auf Owner-Entscheidung
  OPEN // Owner hat akzeptiert, Chat aktiv
  DENIED // Owner hat abgelehnt
  CLOSED // Beendet
}

model Ticket {
  id               String          @id @default(uuid())
  ticketNumber     Int             @unique @default(autoincrement())
  userDiscordId    String // Anfrage-Steller
  username         String
  guildId          String? // Server, von dem die Anfrage kam
  guildName        String?
  subject          String
  initialMessage   String          @db.Text
  status           TicketStatus    @default(PENDING)
  ownerDiscordId   String // Empfaenger (Bot-Owner)
  ownerNoticeMsgId String? // Discord MessageId der DM mit Buttons (zum spaeteren Editieren)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  closedAt         DateTime?
  messages         TicketMessage[]

  @@index([userDiscordId])
  @@index([status])
  @@index([ticketNumber])
}

model TicketMessage {
  id            String   @id @default(uuid())
  ticketId      String
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromDiscordId String // Wer hat geschrieben
  fromRole      String // 'USER' | 'OWNER'
  content       String   @db.Text
  createdAt     DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

// ============================================================
// GUILD-LEVEL SUPPORT-TICKET-SYSTEM (Dashboard Phase 6)
// Eigenes System: Server-Owner konfigurieren bis zu 5 Templates,
// User klickt im konfigurierten Channel auf den Embed-Button und
// bekommt einen privaten Ticket-Channel. Beim Schliessen wird ein
// Markdown-Transcript ins konfigurierte Transcript-Channel gepostet.
// Trennt sich strikt vom Bot-Owner-DM-Bridge-Ticket-System oben.
// ============================================================

model TicketTemplate {
  id                  String           @id @default(uuid())
  guildId             String
  slot                Int // 1..5 pro Guild
  label               String // Anzeige-Name / Channel-Base (z.B. "Support") — Ticket-Ausgabe (Channel-Name + Transcript-Header)
  buttonLabel         String? // Optionaler separater Button-Text (Knopf-Beschriftung). Falls leer, wird `label` als Fallback verwendet.
  welcomeText         String           @db.Text // Legacy/Backward-Compat (= welcomeMessages[0])
  welcomeMessages     Json             @default("[]") // Array<string>, max 5, je 1..2000 Zeichen
  embedTitle          String // Titel des Public-Embeds mit Open-Button
  embedColor          String           @default("#dc2626") // Hex-Color
  postChannelId       String // Channel, in dem der Embed mit Open-Button lebt
  postedMessageId     String? // ID der zuletzt geposteten Embed-Nachricht (zum Edit)
  categoryId          String? // Discord-Category, unter der Ticket-Channels erstellt werden (optional)
  staffRoleId         String? // Rolle die mit-Zugriff auf jeden Ticket-Channel bekommt (optional, legacy single-role)
  managerRoleIds      String[]         @default([]) // Multi-Manager-Rollen: View+Send+ReadHistory + dürfen Tickets schließen (server-side enforced)
  mentionRoleIds      String[]         @default([]) // Rollen die beim Ticket-Open im Channel erwaehnt werden (max 5)
  transcriptChannelId String // Channel fuer Transcript-Uploads beim Close
  archiveChannelId    String? // Optionaler separater Archiv-Channel (zusaetzlich zu Transcript)
  isActive            Boolean          @default(true)
  // Per-Template fortlaufender Ticket-Counter. Wird im Open-Flow atomar inkrementiert
  // und als TicketInstance.templateNumber persistiert. Erlaubt parallele Nummernkreise
  // pro Template (z.B. Support-0007 und Bewerbung-0007 nebeneinander).
  ticketCounter       Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  instances           TicketInstance[]

  @@unique([guildId, slot])
  @@index([guildId])
}

model TicketInstance {
  id                  String         @id @default(uuid())
  ticketNumber        Int            @unique @default(autoincrement()) // Globale interne Sequenz (Legacy/Eindeutigkeit)
  // Pro-Template fortlaufende Nummer. Wird beim Open atomar aus TicketTemplate.ticketCounter
  // gezogen und fuer Channel-Name + Embed + Transcript verwendet. Nullable fuer Legacy-Rows
  // vor der Migration 20260504_ticket_per_template_counter.
  templateNumber      Int?
  templateId          String
  template            TicketTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  guildId             String
  channelId           String         @unique // Discord-Channel des Tickets
  openerDiscordId     String
  openerName          String
  status              String         @default("OPEN") // 'OPEN' | 'CLOSED'
  openedAt            DateTime       @default(now())
  closedAt            DateTime?
  closedBy            String?
  transcriptMessageId String?
  userIds          String[]        @default([])

  @@index([guildId, status])
  @@index([templateId])
  @@index([templateId, templateNumber])
}

// ============================================================
// SEKTION 13: Guild-Awareness (Phase 6)
// Stammdaten pro Discord-Guild, in der der Bot Mitglied ist.
// Wird vom GuildAwareness-Modul aktuell gehalten und in AI-Prompts
// eingespeist, damit die AI weiss, auf welchem Server sie ist.
// ============================================================

model GuildProfile {
  guildId                  String    @id // Discord-Guild-ID
  name                     String
  ownerId                  String? // Discord-User-ID des Server-Owners
  ownerName                String?
  memberCount              Int       @default(0)
  channelCount             Int       @default(0)
  roleCount                Int       @default(0)
  iconUrl                  String?
  preferredLocale          String?
  description              String?   @db.Text
  features                 Json? // string[] mit Discord-Guild-Features
  // Phase 17a: Server-Erstellungsdatum (von Discord), damit Bot "wann wurde der Server erschaffen" beantworten kann.
  serverCreatedAt          DateTime?
  // Phase 7: Channels & Rules Snapshot
  channelsJson             Json? // Array<{ name, type, parent? }> ohne IDs
  rulesText                String?   @db.Text // Inhalt des Rules-Channels (Topic + erste Pins)
  contentSyncedAt          DateTime?
  // Phase 8: Custom Persona-Override und AI-Brief
  aiPersonaOverride        String?   @db.Text // Owner kann zusaetzlichen Persona-Hinweis setzen
  aiBrief                  String?   @db.Text // Auto-generierter Kurz-Brief des Servers
  aiBriefAt                DateTime?
  // Phase 18: Erweiterte Server-Stammdaten fuer praezise AI-Kontextualisierung
  verificationLevel        String? // NONE/LOW/MEDIUM/HIGH/VERY_HIGH
  premiumTier              Int? // Boost-Stufe 0..3
  premiumSubscriptionCount Int? // Anzahl aktiver Boosts
  vanityUrlCode            String?
  bannerUrl                String?
  splashUrl                String?
  afkChannelName           String?
  afkTimeoutSec            Int?
  systemChannelName        String?
  rulesChannelName         String?
  publicUpdatesChannelName String?
  nsfwLevel                String?
  mfaLevel                 String? // NONE/ELEVATED
  emojiCount               Int?
  stickerCount             Int?
  isLarge                  Boolean?
  botCount                 Int?
  topRolesJson             Json? // [{ name, color, position, memberCount? }]
  // Feedback-Channel: wenn gesetzt, werden /feedback-Embeds dorthin gespiegelt
  feedbackChannelId        String?
  joinedAt                 DateTime  @default(now())
  lastSyncedAt             DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  knowledge GuildKnowledge[]
  members   GuildMemberProfile[]

  @@index([name])
}

// Phase 18: Pro Guild eine kompakte Member-Profil-Zeile.
// Wird via messageCreate (throttled) und guildMemberAdd / guildMemberUpdate /
// guildMemberRemove gepflegt. Erlaubt der AI, exakt zu wissen, wer welche
// Rolle hat, wann er beigetreten ist und wann er zuletzt aktiv war.
model GuildMemberProfile {
  id            String       @id @default(uuid())
  guildId       String
  guild         GuildProfile @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  discordId     String
  username      String?
  nickname      String?
  joinedAt      DateTime?
  topRolesJson  Json? // string[] der Top-Rollennamen (max 8)
  isBoosting    Boolean      @default(false)
  boostingSince DateTime?
  isPending     Boolean      @default(false)
  timeoutUntil  DateTime?
  isLeft        Boolean      @default(false) // gesetzt bei guildMemberRemove
  leftAt        DateTime?
  messageCount  Int          @default(0) // Pro Guild gezaehlt
  lastSeenAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([guildId, discordId])
  @@index([guildId])
  @@index([discordId])
  @@index([guildId, lastSeenAt])
}

// Phase 8: Owner/Admin koennen pro Guild eigene Wissens-Snippets hinterlegen,
// die der AI bei thematisch passenden Anfragen eingespeist werden (kompakter
// keyword-basierter Match in contextBuilder).
model GuildKnowledge {
  id        String       @id @default(uuid())
  guildId   String
  guild     GuildProfile @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  label     String // Kurzer Titel, dient zugleich als Schluesselwort-Trigger
  content   String       @db.Text // Faktenblock, max ~2000 Zeichen empfohlen
  createdBy String // Discord-User-ID des Erstellers
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Phase 9 (RAG): Embedding-Cache. Vektor wird als JSON-Array von Floats serialisiert,
  // damit auch ohne pgvector-Extension semantische Suche moeglich ist (JS-Fallback).
  embedding      String?   @db.Text
  embeddingModel String?
  embeddedAt     DateTime?

  @@index([guildId])
  @@index([guildId, isActive])
}

// Phase 10 (B3 Modell-Check): Persistente Statistik je AI-Provider.
// Wird nach jedem callAI-Aufruf in providerStats.recordCall() aktualisiert.
// Dient als Grundlage fuer adaptive Provider-Reihenfolge (success rate gewichtet).
model AiProviderStat {
  id             String    @id @default(uuid())
  provider       String    @unique // 'groq' | 'cerebras' | 'openrouter' | 'gemini' | 'openai'
  successCount   Int       @default(0)
  failureCount   Int       @default(0)
  rateLimitCount Int       @default(0)
  totalLatencyMs BigInt    @default(0) // Summe ueber alle Erfolge -> Avg = totalLatencyMs / successCount
  lastSuccessAt  DateTime?
  lastFailureAt  DateTime?
  lastError      String?
  updatedAt      DateTime  @updatedAt
}

// Phase 14: Conversation Memory. Speichert pro (userId, channelId) die letzten
// Turns zwischen User und Bot, damit /ai mit Kontext zu vorhergehenden Nachrichten
// antworten kann. TTL wird im Modul (conversationMemory.ts) angewandt - hier nur
// die Persistenz. Indexed nach (channelId, userId, createdAt) fuer schnelles Tail.
model AiConversationTurn {
  id        String   @id @default(uuid())
  userId    String
  channelId String
  guildId   String?
  role      String // 'user' | 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId, channelId, createdAt])
  @@index([createdAt])
}

// Phase 17: Auto-Translate Scheduled Messages.
// Speichert geplante / wiederkehrende Posts mit Auto-Translation.
// - mode = 'once'         -> einmaliger Post zum scheduledFor
// - mode = 'recurring'    -> recurrenceCron / recurrenceWeekday + recurrenceTime
// - mode = 'now'          -> sofort (wird nach Versand auf isActive=false gesetzt)
model TranslatedPost {
  id             String    @id @default(uuid())
  guildId        String
  channelId      String
  createdBy      String
  sourceText     String    @db.Text
  sourceLang     String // ISO-Kurzcode der Quellsprache (de/en/fr/...)
  targetLang     String // ISO-Kurzcode der Zielsprache
  translatedText String?   @db.Text // Wird beim ersten Versand befuellt + gecached
  customTitle    String?   @db.VarChar(200) // Optionaler benutzerdefinierter Embed-Titel
  imageUrl       String? // Optionale Bild-URL (Discord-Attachment-Link)
  rolePings      String? // Comma-separated Discord-Role-IDs
  mode           String // 'now' | 'once' | 'recurring'
  scheduledFor   DateTime?
  recurrenceCron String? // Vereinfacht: "WEEKLY:MON:09:00" oder "DAILY:09:00"
  nextRunAt      DateTime?
  lastRunAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([guildId, isActive])
  @@index([nextRunAt, isActive])
}

// ─── Phase B (Quick-Wins User) ───────────────────────────────────────────

// /feedback: User-eingereichte Bug-Reports / Ideen / Lob.
// Geht in Admin-Channel (per BotConfig.feedbackChannelId) und in DB.
model Feedback {
  id              String    @id @default(cuid())
  guildId         String?
  userId          String // Discord-User-ID des Einreichers
  username        String
  category        String // 'BUG' | 'IDEA' | 'PRAISE' | 'OTHER'
  subject         String    @db.VarChar(120)
  message         String    @db.Text
  attachmentUrl   String?
  status          String    @default("OPEN") // 'OPEN' | 'IN_REVIEW' | 'RESOLVED' | 'WONTFIX'
  adminNote       String?   @db.Text
  reviewedBy      String? // Discord-ID des Admins
  reviewedAt      DateTime?
  notifyChannelId String? // Channel, in den die Notify-Nachricht gepostet wurde
  notifyMessageId String? // Message-ID der Notify-Nachricht (fuer Live-Status-Update)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([guildId, status, createdAt])
  @@index([userId])
}

// /erinnerung: User setzt Reminder per DM oder Channel.
// Scheduler prueft alle 30s nextDueAt <= now() AND isActive.
model Reminder {
  id           String   @id @default(cuid())
  userId       String // Discord-User-ID
  guildId      String?
  channelId    String? // Wenn null → DM
  message      String   @db.Text
  dueAt        DateTime
  isRecurring  Boolean  @default(false)
  recurrenceMs Int? // Bei isRecurring=true: Intervall in ms
  isActive     Boolean  @default(true)
  fireCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, isActive])
  @@index([dueAt, isActive])
}

// /selfrole: Admin baut Self-Role-Menu, User bekommt/entfernt Rolle per Button.
// Eine Message kann mehrere SelfRoleOption haben (bis zu 25 Buttons in 5 Rows).
model SelfRoleMenu {
  id          String           @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?          @unique // gefuellt nach erstem Post
  title       String           @db.VarChar(120)
  description String?          @db.Text
  mode        String           @default("MULTI") // 'MULTI' | 'SINGLE' (Single = nur eine Rolle gleichzeitig)
  isActive    Boolean          @default(true)
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  options     SelfRoleOption[]

  @@index([guildId, isActive])
}

model SelfRoleOption {
  id          String       @id @default(cuid())
  menuId      String
  menu        SelfRoleMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  roleId      String
  label       String       @db.VarChar(80)
  emoji       String?
  description String?      @db.VarChar(100)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())

  @@unique([menuId, roleId])
  @@index([menuId, position])
}

// ============================================================
// DASHBOARD V2 — MULTI-GUILD SELF-SERVICE
// Strikte Guild + Nitrado-Server-Slot-Trennung. Siehe plan.md Phase 3.5.
// ============================================================

// Aktivierte Guilds im Dashboard. Wenn der Owner sich einloggt + den
// Bot bereits in der Guild hat, wird hier ein Eintrag angelegt.
model DashboardGuildLink {
  id             String   @id @default(cuid())
  guildId        String   @unique
  ownerDiscordId String
  alias5         String   @unique @db.VarChar(5) // 5-stelliger Identifier (auch im Dashboard sichtbar)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerDiscordId])
}

enum NitradoConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  PROBE_FAILED
}

// Pro Guild bis zu 5 Slots fuer Nitrado-Tokens. Token verschluesselt.
model NitradoConnection {
  id               String                  @id @default(cuid())
  guildId          String
  slot             Int // 1..5
  alias            String                  @db.VarChar(40)
  alias5           String                  @unique @db.VarChar(5) // pro-Slot eigener 5-stelliger Identifier
  encryptedToken   String                  @db.Text
  nitradoServerId  String?
  serviceId        String? // Nitrado-Service-ID
  status           NitradoConnectionStatus @default(ACTIVE)
  lastValidatedAt  DateTime?
  lastErrorMessage String?                 @db.Text
  addedByDiscordId String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  serverSettings    ServerSettings[]
  whitelistEntries  WhitelistEntry[]
  whitelistRequests WhitelistRequest[]
  factions          Faction[]
  factionConfigs    FactionSystemConfig[]
  economyLinks      EconomyLink[]
  mirrorSnapshots   NitradoSnapshot[]
  killfeedConfigs   KillfeedConfig[]
  killfeedEvents    KillfeedEvent[]

  @@unique([guildId, slot])
  @@index([guildId])
}

// Subuser-Permissions pro Guild. Owner darf delegieren, ausser
// `nitrado.manage` (hardcoded blockiert auf Code-Ebene, hier nur Doku).
model GuildPermissionGrant {
  id                 String   @id @default(cuid())
  guildId            String
  userDiscordId      String
  permissions        Json // { "economy.manage": true, "whitelist.view": true, ... }
  grantedByDiscordId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([guildId, userDiscordId])
  @@index([guildId])
}

/// Wie GuildPermissionGrant, aber zielt auf eine Discord-ROLLE statt auf einen
/// einzelnen User. Beim Permission-Check werden alle Rollen des aktiven Users
/// in der Guild gegen diese Tabelle geprueft (Vereinigung aller Rollen-Scopes).
model GuildPermissionRoleGrant {
  id                 String   @id @default(cuid())
  guildId            String
  roleDiscordId      String
  permissions        Json // wie oben: Array von Scope-Strings
  grantedByDiscordId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([guildId, roleDiscordId])
  @@index([guildId])
}

// Settings pro (Guild + Nitrado-Slot). Whitelist/Economy/PermaOnly-Toggles.
model ServerSettings {
  id                           String            @id @default(cuid())
  guildId                      String
  nitradoConnId                String
  nitradoConn                  NitradoConnection @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  whitelistActive              Boolean           @default(false)
  economyActive                Boolean           @default(false)
  permaOnly                    Boolean           @default(false)
  whitelistChannelId           String?
  whitelistRequestChannelId    String?
  whitelistInfoMessageId       String?
  whitelistApproveLogChannelId String?
  whitelistDenyLogChannelId    String?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  @@unique([guildId, nitradoConnId])
  @@index([guildId])
}

// Fraktionen pro (Guild + Nitrado-Slot). Embed-Push beim Save.
model Faction {
  id                 String            @id @default(cuid())
  guildId            String
  nitradoConnId      String
  nitradoConn        NitradoConnection @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  name               String            @db.VarChar(60)
  flagUrl            String?           @db.Text // optional: URL ODER lokaler Pfad /uploads/factions/...
  bannerUrl          String?           @db.Text
  mediaUrl           String?           @db.Text // optionales JPG/MP4 (Armband/Logo)
  leaderDiscordId    String?
  deputyDiscordId    String? // Stellvertretung (separat von Treasurer)
  treasurerDiscordId String?
  embedChannelId     String?
  embedMessageId     String?
  roleId             String? // Optionale Discord-Rolle: wird Mitgliedern automatisch zugewiesen / entfernt.
  joinPolicy         String            @default("REQUEST") // 'OPEN' | 'REQUEST' | 'CLOSED'
  status             String            @default("ACTIVE") @db.VarChar(16) // 'ACTIVE' | 'RECRUITING' | 'INACTIVE' | 'ARCHIVED'
  description        String?           @db.Text
  color              String?           @db.VarChar(7) // Hex z.B. '#dc2626'
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  members            FactionMember[]

  @@unique([guildId, nitradoConnId, name])
  @@index([guildId])
}

// Globale Konfiguration des Fraktionssystems pro (Guild + Slot).
// factionChannelId: Sammelkanal — alle Fraktionen-Embeds + Uebersichts-Liste landen hier automatisch.
// listMessageId:    ID des Uebersichts-Embeds (Liste aller Fraktionen).
model FactionSystemConfig {
  id               String            @id @default(cuid())
  guildId          String
  nitradoConnId    String
  nitradoConn      NitradoConnection @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  factionChannelId String?
  listMessageId    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([guildId, nitradoConnId])
  @@index([guildId])
}

model FactionMember {
  id            String   @id @default(cuid())
  factionId     String
  faction       Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  userDiscordId String
  role          String   @default("MEMBER") // 'LEADER' | 'TREASURER' | 'MEMBER' | 'PENDING'
  joinedAt      DateTime @default(now())

  @@unique([factionId, userDiscordId])
  @@index([userDiscordId])
}

// Whitelist auf Nitrado. DB ist Spiegel der Nitrado-API + lokale History.
model WhitelistEntry {
  id                  String            @id @default(cuid())
  guildId             String
  nitradoConnId       String
  nitradoConn         NitradoConnection @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  gameId              String // Spielername (Nitrado managed Whitelist by name)
  approvedByDiscordId String
  source              String            @default("DIRECT") // 'DIRECT' | 'REQUEST' | 'IMPORT'
  approvedAt          DateTime          @default(now())

  @@unique([guildId, nitradoConnId, gameId])
  @@index([guildId])
}

enum WhitelistRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

model WhitelistRequest {
  id                 String                 @id @default(cuid())
  guildId            String
  nitradoConnId      String
  nitradoConn        NitradoConnection      @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  channelId          String
  messageId          String?                @unique
  requesterDiscordId String
  gameId             String
  status             WhitelistRequestStatus @default(PENDING)
  decidedByDiscordId String?
  decidedAt          DateTime?
  reason             String?                @db.Text
  createdAt          DateTime               @default(now())

  @@index([guildId, status])
}

// Economy-Konfiguration pro Guild.
model EconomyConfig {
  id                    String   @id @default(cuid())
  guildId               String   @unique
  currencyName          String   @default("Coins") @db.VarChar(40)
  emoji                 String   @default("💰") @db.VarChar(40)
  enabled               Boolean  @default(false)
  startBalance          Int      @default(0) // bei guildMemberAdd, optional
  playtimeRewardPercent Int      @default(5) // 5..unbegrenzt — pro Spielminute Coins
  bankChannelId         String?
  bankInterestPercent   Int      @default(0) // pro Tag, optional
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([guildId])
}

model EconomyAccount {
  id             String   @id @default(cuid())
  guildId        String
  userDiscordId  String
  walletBalance  BigInt   @default(0) // direkt nutzbar (Casino, Pay)
  bankBalance    BigInt   @default(0) // sicher (Zinsen, Transfer)
  lifetimeEarned BigInt   @default(0)
  lifetimeSpent  BigInt   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([guildId, userDiscordId])
  @@index([guildId])
}

enum EconomyTxType {
  PAY
  ADMIN_PAY
  DEPOSIT
  WITHDRAW
  TRANSFER
  CASINO_BET
  CASINO_PAYOUT
  PLAYTIME_REWARD
  STARTBALANCE_JOIN
  GRANT
  FINE
  INTEREST
}

// Audit-Trail jeder Balance-Aenderung. Atomar mit Account-Update.
model EconomyTransaction {
  id                   String        @id @default(cuid())
  guildId              String
  userDiscordId        String // Empfaenger der Aenderung
  delta                BigInt // positiv = Gutschrift, negativ = Abzug
  type                 EconomyTxType
  reason               String?       @db.VarChar(200)
  actorDiscordId       String? // null bei System-Tx (Zinsen, Playtime)
  counterpartDiscordId String? // bei Pay/Transfer der Andere
  createdAt            DateTime      @default(now())

  @@index([guildId, userDiscordId, createdAt])
  @@index([guildId, createdAt])
}

// Discord <-> Nitrado-Spielername Bindung pro (Guild + Slot + User).
model EconomyLink {
  id            String            @id @default(cuid())
  guildId       String
  nitradoConnId String
  nitradoConn   NitradoConnection @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  userDiscordId String
  gameId        String // Steam64 oder Charname
  linkedAt      DateTime          @default(now())
  lastSeenAt    DateTime?

  @@unique([guildId, nitradoConnId, userDiscordId])
  @@unique([guildId, nitradoConnId, gameId])
  @@index([guildId])
}

enum CasinoGameType {
  SLOT
  COINFLIP
  DICE
  BLACKJACK
}

// Spiel-Konfiguration pro Guild und Spieltyp.
model CasinoGame {
  id           String         @id @default(cuid())
  guildId      String
  type         CasinoGameType
  enabled      Boolean        @default(true)
  winChancePct Int            @default(45) // 1..99
  minBet       BigInt         @default(1)
  maxBet       BigInt         @default(10000)
  payoutMult   Float          @default(2.0) // Auszahlungsmultiplikator
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  rounds       CasinoRound[]

  @@unique([guildId, type])
}

// Spielprotokoll. Provably-Fair: serverSeed + clientSeed + nonce.
model CasinoRound {
  id            String     @id @default(cuid())
  gameId        String
  game          CasinoGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  guildId       String
  userDiscordId String
  bet           BigInt
  payout        BigInt     @default(0)
  result        Json // { won: bool, details: {...} }
  serverSeed    String     @db.VarChar(128)
  clientSeed    String?    @db.VarChar(128)
  nonce         BigInt     @default(0)
  createdAt     DateTime   @default(now())

  @@index([guildId, userDiscordId, createdAt])
  @@index([gameId, createdAt])
}

// DEV-Sessions (separater Login-Pfad fuer Live-Konsole).
model DevSession {
  id            String    @id @default(cuid())
  userDiscordId String
  scope         Json // { logs: true, restart: false, ... }
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  @@index([userDiscordId])
  @@index([expiresAt])
}

// DEV-Uploads (ADM/RPT/XML/JSON-Logs zur Analyse, Phase 2).
// Per-User isoliert; TTL via expiresAt + Cleanup-Job.
// Inhalt liegt unter uploads/dev-logs/<userDiscordId>/<id>/<safeName>.
model DevUpload {
  id            String    @id @default(cuid())
  userDiscordId String
  kind          String    @db.VarChar(8) // 'ADM' | 'RPT' | 'XML' | 'JSON'
  originalName  String    @db.VarChar(255)
  storedPath    String    @db.VarChar(512) // relativ zu uploads/, z.B. dev-logs/<uid>/<id>/log.adm
  mimeType      String    @db.VarChar(120)
  sizeBytes     Int
  sha256        String    @db.VarChar(64)
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  deletedAt     DateTime?

  @@index([userDiscordId, createdAt])
  @@index([expiresAt])
}

// Idempotenz-Keys fuer alle Mutation-Routen (Haertung A1).
model IdempotencyKey {
  hash           String   @id // sha256 von (userId + route + body)
  responseBody   Json
  responseStatus Int
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

enum NitradoJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  DEAD
}

// Outbox fuer Nitrado-API-Calls (Haertung A2). Worker pickt PENDING + nextRunAt<=now.
model NitradoJob {
  id            String           @id @default(cuid())
  guildId       String
  nitradoConnId String
  operation     String           @db.VarChar(40) // 'WHITELIST_ADD' | 'WHITELIST_REMOVE' | 'KEEPALIVE' | 'DOWNLOAD_ADM' | 'RESTART_IF_DOWN'
  payload       Json
  status        NitradoJobStatus @default(PENDING)
  attempts      Int              @default(0)
  maxAttempts   Int              @default(8)
  nextRunAt     DateTime         @default(now())
  lastError     String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status, nextRunAt])
  @@index([guildId])
}

// ============================================================
// NITRADO MIRROR (READ-ONLY) — Einmaliger Voll-Snapshot pro
// NitradoConnection. Strikt nur GET-Aufrufe. Datei-Inhalte
// inhaltsadressiert auf Disk unter
// uploads/nitrado-mirror/<connId>/<sha256>. Zweck: lückenlose
// Quelle für Bot-/KI-Antworten zu DayZ-Server-Daten.
// ============================================================

enum NitradoSnapshotStatus {
  RUNNING
  OK
  PARTIAL
  FAILED
}

model NitradoSnapshot {
  id              String                @id @default(cuid())
  guildId         String
  nitradoConnId   String
  nitradoConn     NitradoConnection     @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  serviceId       String? // Nitrado-Service-ID zum Snapshot-Zeitpunkt
  startedAt       DateTime              @default(now())
  finishedAt      DateTime?
  status          NitradoSnapshotStatus @default(RUNNING)
  totalFiles      Int                   @default(0)
  totalDirs       Int                   @default(0)
  totalBytes      BigInt                @default(0)
  storedBytes     BigInt                @default(0) // tatsächlich auf Disk geschrieben (ohne übergroße)
  oversizeFiles   Int                   @default(0) // > MAX_FILE_BYTES, nur Meta gespeichert
  errorCount      Int                   @default(0)
  lastError       String?               @db.Text
  triggeredBy     String // Discord-User-Id
  settingsJson    Json? // komplettes /services/{id}/gameservers Antwort-Objekt
  serviceMetaJson Json? // Eintrag aus /services
  files           NitradoSnapshotFile[]

  @@index([guildId, nitradoConnId, startedAt])
  @@index([nitradoConnId, status])
}

model NitradoSnapshotFile {
  id          String          @id @default(cuid())
  snapshotId  String
  snapshot    NitradoSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  path        String          @db.VarChar(1024) // absoluter Pfad innerhalb des Gameservers
  name        String          @db.VarChar(512)
  parentDir   String          @db.VarChar(1024)
  isDir       Boolean         @default(false)
  sizeBytes   BigInt          @default(0)
  modifiedAt  DateTime?
  sha256      String?         @db.VarChar(64)
  mimeGuess   String?         @db.VarChar(120)
  isText      Boolean         @default(false)
  contentText String?         @db.Text // nur für Text < INLINE_TEXT_BYTES
  storedPath  String?         @db.VarChar(512) // relativ zu uploads/, falls auf Disk
  oversize    Boolean         @default(false) // übergroß: nur Meta
  errorMsg    String?         @db.Text

  @@index([snapshotId, parentDir])
  @@index([snapshotId, name])
  @@index([snapshotId, sha256])
}

// ============================================================
// KILLFEED — Live-PvP-Tracking aus DayZ ADM-Logs
// Polling im 60s-Takt mit ETag/If-Modified-Since.
// ============================================================
enum KillCategory {
  DEATH
  SUICIDE
  NPC
  VEHICLE
}

model KillfeedConfig {
  id            String            @id @default(cuid())
  guildId       String
  nitradoConnId String
  nitradoConn   NitradoConnection @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  channelId     String            @db.VarChar(32)
  isActive      Boolean           @default(true)
  categories    KillCategory[]

  // Anzeige-Toggles
  showShooterCoords Boolean @default(false)
  showVictimCoords  Boolean @default(true)
  showWeapon        Boolean @default(true)
  showDistance      Boolean @default(true)
  embedColor        String  @default("#dc2626") @db.VarChar(9)

  // Polling-State
  lastEventAt    DateTime?
  lastEtag       String?   @db.VarChar(128)
  lastFileName   String?   @db.VarChar(256)
  lastByteOffset BigInt    @default(0)
  lastPolledAt   DateTime?
  lastErrorMsg   String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, nitradoConnId, channelId])
  @@index([guildId, nitradoConnId])
  @@index([guildId, isActive])
}

model KillfeedEvent {
  id            String            @id @default(cuid())
  guildId       String
  nitradoConnId String
  nitradoConn   NitradoConnection @relation(fields: [nitradoConnId], references: [id], onDelete: Cascade)
  category      KillCategory
  occurredAt    DateTime
  shooterName   String?           @db.VarChar(120)
  shooterPos    String?           @db.VarChar(120)
  victimName    String            @db.VarChar(120)
  victimPos     String?           @db.VarChar(120)
  weapon        String?           @db.VarChar(120)
  distance      Float?
  rawLine       String            @db.Text
  postedAt      DateTime?
  createdAt     DateTime          @default(now())

  @@index([guildId, nitradoConnId, occurredAt])
  @@index([guildId, nitradoConnId, category])
}

# =============================================
# Discord-V-Bot Konfiguration
# =============================================

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_GUILD_ID=your_guild_id_here
BOT_OWNER_ID=your_discord_user_id_here

# Datenbank (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/discord_v_bot?schema=public

# Web-Dashboard
DASHBOARD_PORT=3000
DASHBOARD_URL=http://localhost:3000
SESSION_SECRET=your_session_secret_here_min_64_chars
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback

# Sicherheit
ADMIN_PASSWORD_HASH=
TWO_FACTOR_ISSUER=Discord-V-Bot
ENCRYPTION_KEY=your_32_byte_encryption_key_hex

# Upload-System
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=2147483648
ALLOWED_EXTENSIONS=.xml,.json

# AI-Integration (optional)
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4

# Externe APIs (optional)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=
STEAM_API_KEY=

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

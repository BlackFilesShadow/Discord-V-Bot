# =============================================
# Discord-V-Bot Konfiguration
# =============================================
#
# HINWEIS: Alle mit "your_..."/"changeme" markierten Werte sind PLATZHALTER und
# NICHT produktionsfaehig. In Production (NODE_ENV=production) bricht der Start
# ab, solange ein Pflicht-Secret noch einen Platzhalterwert traegt.

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_GUILD_ID=your_guild_id_here
BOT_OWNER_ID=your_discord_user_id_here

# Datenbank (PostgreSQL)
# Bei Docker-Compose: postgres als Hostname; ansonsten localhost o.ae.
# WICHTIG: "changeme" ist nur fuer lokale Entwicklung. In Production wird ein
# DATABASE_URL mit "changeme" beim Start abgelehnt.
DATABASE_URL=postgresql://discordbot:changeme@postgres:5432/discord_v_bot?schema=public

# Postgres-Credentials (von docker-compose.yml verwendet)
# In Production ein starkes, zufaelliges Passwort setzen (kein "changeme").
POSTGRES_DB=discord_v_bot
POSTGRES_USER=discordbot
POSTGRES_PASSWORD=changeme

# Web-Dashboard
DASHBOARD_PORT=3000
DASHBOARD_URL=http://localhost:3000
SESSION_SECRET=your_session_secret_here_min_64_chars
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback

# Sicherheit
ADMIN_PASSWORD_HASH=
TWO_FACTOR_ISSUER=Discord-V-Bot
ENCRYPTION_KEY=your_32_byte_encryption_key_hex

# Developer-Bereich (Passwort für /dev-* Commands)
# WICHTIG: Eigenen, zufaelligen Wert mit >= 12 Zeichen setzen. Kein Default!
DEV_PASSWORD=change_me_to_a_long_random_secret

# DEV-Zugriff ist bewusst NUR passwortgeschützt (DEV_PASSWORD).
# 2FA und IP-Allowlist sind OPTIONALE Opt-in-Features (Default AUS) und werden
# in Production NICHT erzwungen. Nur bei "=true" greift die jeweilige Prüfung.
#   DEV_REQUIRE_MFA=true            -> optionaler 2FA-Zwang
#   DEV_REQUIRE_IP_ALLOWLIST=true  -> optionale IP-Allowlist (DB-WHITELIST)
DEV_REQUIRE_MFA=false
DEV_REQUIRE_IP_ALLOWLIST=false
DEV_IP_ALLOWLIST=

# Member-Erfassung (Spec §11): GuildMembers-Intent wird benoetigt (im Discord
# Developer Portal aktivieren). Optionaler Hintergrund-Sync ist standardmaessig AUS.
#   MEMBER_SYNC_ENABLED=true        -> rate-limit-freundlicher Member-Sync-Job
#   MEMBER_SYNC_INTERVAL_HOURS=12   -> Intervall (1..24, default 12)
MEMBER_SYNC_ENABLED=false
MEMBER_SYNC_INTERVAL_HOURS=12

# Nitrado (Spec §12): Extra-Schreibschutz fuer gefaehrliche Aktionen.
# Standard AN — Writes brauchen Confirm + Reason + Audit. Nur explizit deaktivieren:
#   NITRADO_WRITE_PROTECTION=false  -> Writes ohne Extra-Bestaetigung
NITRADO_WRITE_PROTECTION=true


# Upload-System
UPLOAD_DIR=./uploads
# Private Ablagen AUSSERHALB des oeffentlichen /uploads (nie per express.static):
PRIVATE_UPLOAD_DIR=./private
DEV_UPLOAD_DIR=./private/dev-logs
EXPORT_DIR=./private/exports
MAX_FILE_SIZE_BYTES=2147483648
ALLOWED_EXTENSIONS=.xml,.json

# Reverse-Proxy: Express trust-proxy-Wert. Standard 1 (genau ein Proxy davor).
# Zahl (Hop-Anzahl), true/false oder CIDR/IP-Liste moeglich. Siehe README.
TRUST_PROXY=1

# AI-Integration (mindestens einen Provider konfigurieren)
# Provider-Prioritaet: groq | cerebras | openrouter | gemini | openai (Standard: groq)
AI_PROVIDER=groq

# Groq (kostenlos, empfohlen)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras (optional)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini (kostenlos)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (kostenpflichtig, Fallback)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Externe APIs (optional)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=
STEAM_API_KEY=

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

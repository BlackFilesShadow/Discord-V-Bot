{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    "group:allNonMajor",
    "schedule:weekly"
  ],
  "timezone": "Europe/Berlin",
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Auto-merge devDependencies patch + minor",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Auto-merge production patch updates",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Manual review for major bumps",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-bump", "needs-review"],
      "automerge": false
    },
    {
      "description": "Pin Discord.js (frequent breaking changes)",
      "matchPackageNames": ["discord.js"],
      "automerge": false,
      "labels": ["dependencies", "discord-js", "needs-review"]
    },
    {
      "description": "Pin Prisma (schema migrations need manual review)",
      "matchPackageNames": ["prisma", "@prisma/client"],
      "automerge": false,
      "labels": ["dependencies", "prisma", "needs-review"],
      "groupName": "prisma packages"
    },
    {
      "description": "Group all ESLint-related",
      "matchPackagePatterns": ["eslint"],
      "groupName": "eslint packages"
    },
    {
      "description": "Group all Jest-related",
      "matchPackagePatterns": ["^jest", "^@types/jest", "ts-jest"],
      "groupName": "jest packages"
    }
  ],
  "postUpdateOptions": ["npmDedupe"]
}
